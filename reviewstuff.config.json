{
  "concurrency": 3,
  "timeoutSeconds": 180,
  "failOn": "error",
  "rulesFile": ".reviewstuff/rules.md",
  "gates": {
    "typecheck": "pnpm typecheck",
    "test": "pnpm vitest run test/unit"
  },
  "reviewers": {
    "correctness": {
      "model": "openai-codex/gpt-5.5"
    },
    "security": {
      "model": "anthropic/claude-sonnet-5"
    },
    "typescript": {
      "model": "openai-codex/gpt-5.5"
    }
  }
}
